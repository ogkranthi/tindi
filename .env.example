# Copy to .env.local and fill in. Never commit your real key.

# OpenRouter — used for all AI model calls (meal plans, insights, recommendations).
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Which model to route to. Any OpenRouter model slug works; swap freely.
# Good defaults: a capable general model for planning/reasoning.
OPENROUTER_MODEL=anthropic/claude-sonnet-4.6

# Optional: shown to OpenRouter for rankings/attribution (safe to leave blank).
OPENROUTER_APP_URL=http://localhost:3000
OPENROUTER_APP_NAME=Tindi

# Where the SQLite file lives (defaults to ./data/tindi.db if unset).
TINDI_DB_PATH=./data/tindi.db
